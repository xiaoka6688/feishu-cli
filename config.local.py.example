# config.local.py - 个人凭证配置文件（**不要提交到 Git**）
#
# 用法：
#   1. 复制本文件为 config.local.py
#   2. 填入你的飞书 App ID 和 App Secret
#   3. 把它加入 .gitignore
#
# 或者直接设环境变量（推荐，CI/CD 友好）：
#   export FEISHU_APP_ID="cli_xxx"
#   export FEISHU_APP_SECRET="xxx"
#   export FEISHU_CLI_PATH="/path/to/feishu-cli"

# 飞书 App 凭证（从 https://open.feishu.cn/app 拿到）
APP_ID = "cli_xxxxxxxxxxxxx"
APP_SECRET = "your_secret_here"

# feishu-cli 二进制路径
FEISHU_CLI = r"C:\Users\你的用户名\go\bin\feishu-cli.exe"

# 默认 Obsidian Vault 路径
DEFAULT_VAULT = r"G:\飞书知识库"
